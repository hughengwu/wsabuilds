<ExternalCamera>
    <Provider>
        <!-- WSA's Windows camera HAL owns no /dev/videoN nodes; our UVC webcam
             (usbip-attached) shows up as /dev/video0..N. Do not ignore any. -->
        <ignore>
        </ignore>
    </Provider>
    <!-- See ExternalCameraUtils.cpp for default values. CloudWalk (云从) liveness
         requests 640x360 / 640x480 preview via the Camera1 legacy path. The HAL
         derives stream sizes from the V4L2 device and crop+scales as needed. -->
    <Device>
        <MaxJpegBufferSize bytes="3145728"/>
        <NumVideoBuffers count="4"/>
        <NumStillBuffers count="2"/>
        <FpsList>
            <Limit width="640"  height="360"  fpsBound="30.0"/>
            <Limit width="640"  height="480"  fpsBound="30.0"/>
            <Limit width="1280" height="720"  fpsBound="30.0"/>
            <Limit width="1920" height="1080" fpsBound="10.0"/>
        </FpsList>
    </Device>
</ExternalCamera>
