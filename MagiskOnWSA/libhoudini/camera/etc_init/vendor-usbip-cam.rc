# Auto-attach the Windows-side UVC webcam over usbip at boot, so the AOSP
# External Camera HAL sees it as /dev/video0. Runs in the hal_camera_default
# domain (made permissive by our baked sepolicy) and keeps retrying until the
# host-side `usbipd bind` is in effect (budget 300s).
#
# Host IP is auto-derived from eth0's subnet (.1), so it survives the vEthernet
# IP changing across reboots. busid 1-6 = the webcam's USB port on the host;
# change only if you plug the camera into a different physical port.
service vendor-usbip-cam /vendor/bin/usbip_attach_min auto 1-6 300
    class hal
    user root
    group root system
    seclabel u:r:hal_camera_default:s0
    oneshot
    disabled

on property:sys.boot_completed=1
    start vendor-usbip-cam
